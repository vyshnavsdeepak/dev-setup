[user]
	name = Your Name
	email = user@work.example.com
	signingkey = YOUR_WORK_GPG_KEY_ID
[init]
	defaultBranch = main
[core]
	editor = nvim
	excludesfile = ~/.gitignore_global
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	side-by-side = true
	line-numbers = true
[merge]
	conflictstyle = zdiff3
[pull]
	rebase = true
[fetch]
	prune = true
[rerere]
	enabled = true
[commit]
	gpgsign = true
[tag]
	gpgsign = true
[gpg]
	program = gpg
[includeIf "gitdir:~/src/github.com/vyshnavsdeepak/"]
	path = ~/.gitconfig-personal
